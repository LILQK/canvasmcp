{
  "name": "@canvas-mcp/server",
  "version": "0.1.1",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "canvasmcp": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE",
    ".env.example",
    "package.json"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --enable-source-maps dist/src/cli.js run",
    "dev": "tsx src/cli.ts run",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "dotenv": "^17.2.3",
    "playwright": "1.58.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
